<!DOCTYPE html>
<html lang="es">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Ruleta de Descuentos · Ferrati Sport</title>
<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link href="https://fonts.googleapis.com/css2?family=Russo+One&family=Barlow+Condensed:wght@400;600;700;800;900&family=Barlow:wght@400;500;600;700&display=swap" rel="stylesheet">
<style>
  :root{
    --red:#E30613;
    --red-dark:#B30410;
    --orange:#F26522;
    --navy:#0B1220;
    --ink:#0E0E10;
    --bone:#F4F1EC;
    --paper:#FAFAF7;
    --gold:#D4A24C;
  }
  *{box-sizing:border-box;margin:0;padding:0}
  html,body{height:100%}
  body{
    font-family:'Barlow', sans-serif;
    background:
      radial-gradient(1200px 600px at 80% -10%, rgba(227,6,19,.18), transparent 60%),
      radial-gradient(900px 500px at -10% 110%, rgba(242,101,34,.14), transparent 60%),
      linear-gradient(180deg, #0a0d14 0%, #11141d 100%);
    color:var(--bone);
    min-height:100vh;
    overflow-x:hidden;
  }
  /* Grain texture overlay */
  body::before{
    content:"";position:fixed;inset:0;pointer-events:none;z-index:1;opacity:.06;
    background-image:url("data:image/svg+xml;utf8,<svg xmlns='http://www.w3.org/2000/svg' width='200' height='200'><filter id='n'><feTurbulence type='fractalNoise' baseFrequency='.9' numOctaves='2' stitchTiles='stitch'/></filter><rect width='100%' height='100%' filter='url(%23n)'/></svg>");
  }
  /* Speed lines decoration */
  .speedlines{
    position:fixed;inset:0;pointer-events:none;z-index:0;opacity:.4;
    background:
      linear-gradient(90deg, transparent 0%, transparent 49.5%, rgba(255,255,255,.04) 50%, transparent 50.5%, transparent 100%),
      linear-gradient(90deg, transparent 0%, transparent 49.5%, rgba(227,6,19,.06) 50%, transparent 50.5%, transparent 100%);
    background-size: 80px 100%, 240px 100%;
  }

  .app{position:relative;z-index:2;min-height:100vh;display:flex;flex-direction:column;align-items:center;padding:24px 16px 60px;}

  /* HEADER */
  header.top{
    display:flex;align-items:center;justify-content:space-between;gap:20px;
    width:100%;max-width:1100px;margin-bottom:28px;
  }
  .brand-mark{display:flex;align-items:center;gap:14px}
  .brand-mark img{height:42px;width:auto;filter:drop-shadow(0 2px 8px rgba(227,6,19,.4))}
  .brand-mark .reto-mini{height:54px;filter:drop-shadow(0 2px 6px rgba(242,101,34,.4))}
  .divider-v{width:1px;height:36px;background:linear-gradient(180deg, transparent, rgba(255,255,255,.25), transparent)}
  .event-tag{
    font-family:'Barlow Condensed', sans-serif;
    font-weight:700;font-size:13px;letter-spacing:.18em;text-transform:uppercase;
    color:#fff;opacity:.7;
  }
  .event-tag span{color:var(--orange)}

  /* HERO */
  .hero{text-align:center;max-width:880px;margin:8px auto 36px}
  .kicker{
    display:inline-block;
    font-family:'Barlow Condensed', sans-serif;font-weight:700;
    font-size:12px;letter-spacing:.35em;text-transform:uppercase;
    color:var(--orange);
    padding:6px 14px;border:1px solid rgba(242,101,34,.4);
    border-radius:999px;background:rgba(242,101,34,.06);
    margin-bottom:18px;
  }
  h1{
    font-family:'Russo One', sans-serif;
    font-size:clamp(36px, 6vw, 64px);
    line-height:.95;letter-spacing:-.01em;text-transform:uppercase;
    color:#fff;
  }
  h1 .accent{
    background:linear-gradient(90deg, var(--red) 0%, var(--orange) 100%);
    -webkit-background-clip:text;background-clip:text;color:transparent;
    display:inline-block;transform:skew(-6deg);padding:0 6px;
  }
  .subtitle{
    margin-top:14px;font-size:17px;line-height:1.5;color:rgba(244,241,236,.7);
    max-width:600px;margin-left:auto;margin-right:auto;
  }

  /* STEP INDICATOR */
  .steps{
    display:flex;gap:8px;justify-content:center;align-items:center;
    margin:24px 0 8px;flex-wrap:wrap;
  }
  .step-pill{
    display:flex;align-items:center;gap:8px;
    font-family:'Barlow Condensed', sans-serif;font-weight:700;
    font-size:12px;letter-spacing:.15em;text-transform:uppercase;
    color:rgba(244,241,236,.4);
    padding:6px 12px;border-radius:999px;
    border:1px solid rgba(255,255,255,.08);
    transition:all .3s ease;
  }
  .step-pill.active{color:#fff;border-color:var(--red);background:rgba(227,6,19,.12)}
  .step-pill.done{color:var(--orange);border-color:rgba(242,101,34,.3)}
  .step-pill .num{
    display:inline-flex;align-items:center;justify-content:center;
    width:18px;height:18px;border-radius:50%;font-size:11px;
    background:rgba(255,255,255,.08);
  }
  .step-pill.active .num{background:var(--red);color:#fff}
  .step-pill.done .num{background:var(--orange);color:#0a0d14}
  .step-arrow{color:rgba(255,255,255,.2);font-size:11px}

  /* STAGE CONTAINER */
  .stage{
    width:100%;max-width:1100px;
    position:relative;
  }
  .panel{
    display:none;animation:fadeUp .5s ease both;
  }
  .panel.active{display:block}
  @keyframes fadeUp{
    from{opacity:0;transform:translateY(20px)}
    to{opacity:1;transform:translateY(0)}
  }

  /* INSTAGRAM PANEL */
  .ig-card{
    max-width:540px;margin:0 auto;
    background:linear-gradient(180deg, rgba(255,255,255,.04), rgba(255,255,255,.01));
    border:1px solid rgba(255,255,255,.1);
    border-radius:24px;
    padding:36px 28px;
    text-align:center;
    backdrop-filter: blur(20px);
    position:relative;overflow:hidden;
  }
  .ig-card::before{
    content:"";position:absolute;top:-1px;left:20%;right:20%;height:1px;
    background:linear-gradient(90deg, transparent, var(--red), transparent);
  }
  .ig-icon{
    width:72px;height:72px;margin:0 auto 18px;
    border-radius:20px;
    background:linear-gradient(135deg, #f09433 0%, #e6683c 25%, #dc2743 50%, #cc2366 75%, #bc1888 100%);
    display:flex;align-items:center;justify-content:center;
    box-shadow: 0 12px 40px rgba(220,39,67,.4), inset 0 1px 0 rgba(255,255,255,.3);
  }
  .ig-icon svg{width:38px;height:38px;color:#fff}
  .ig-card h2{
    font-family:'Russo One', sans-serif;
    font-size:26px;text-transform:uppercase;line-height:1.05;
    margin-bottom:10px;color:#fff;
  }
  .ig-card p{color:rgba(244,241,236,.65);font-size:15px;line-height:1.5;margin-bottom:22px}
  .ig-handle{
    display:inline-flex;align-items:center;gap:8px;
    font-family:'Barlow Condensed', sans-serif;font-weight:700;
    font-size:18px;letter-spacing:.05em;
    color:#fff;
    padding:10px 18px;border-radius:12px;
    background:rgba(0,0,0,.3);border:1px dashed rgba(255,255,255,.15);
    margin-bottom:24px;
  }
  .ig-handle::before{content:"@";color:var(--orange);font-weight:900}

  /* FORM */
  .form-block{margin:18px 0 22px;text-align:left}
  .form-block label{
    display:block;font-family:'Barlow Condensed', sans-serif;font-weight:700;
    font-size:12px;letter-spacing:.2em;text-transform:uppercase;
    color:rgba(244,241,236,.55);margin-bottom:8px;
  }
  .form-block input{
    width:100%;padding:14px 16px;
    background:rgba(0,0,0,.35);
    border:1px solid rgba(255,255,255,.12);
    border-radius:10px;
    color:#fff;font-size:16px;font-family:'Barlow', sans-serif;
    transition:all .25s ease;
  }
  .form-block input:focus{
    outline:none;border-color:var(--red);
    box-shadow:0 0 0 3px rgba(227,6,19,.15);
    background:rgba(0,0,0,.5);
  }
  .form-block input::placeholder{color:rgba(244,241,236,.3)}

  /* BUTTONS */
  .btn{
    display:inline-flex;align-items:center;justify-content:center;gap:10px;
    font-family:'Russo One', sans-serif;font-size:15px;letter-spacing:.08em;
    text-transform:uppercase;
    padding:16px 28px;border:none;border-radius:12px;
    cursor:pointer;transition:all .25s ease;
    text-decoration:none;color:#fff;
    position:relative;overflow:hidden;
  }
  .btn-primary{
    background:linear-gradient(135deg, var(--red) 0%, var(--red-dark) 100%);
    box-shadow: 0 10px 30px rgba(227,6,19,.35), inset 0 1px 0 rgba(255,255,255,.2);
  }
  .btn-primary:hover{transform:translateY(-2px);box-shadow:0 14px 40px rgba(227,6,19,.5)}
  .btn-primary:active{transform:translateY(0)}
  .btn-primary::after{
    content:"";position:absolute;top:0;left:-100%;width:100%;height:100%;
    background:linear-gradient(90deg, transparent, rgba(255,255,255,.25), transparent);
    transition:left .6s ease;
  }
  .btn-primary:hover::after{left:100%}
  .btn-ghost{
    background:transparent;border:1px solid rgba(255,255,255,.2);color:#fff;
  }
  .btn-ghost:hover{background:rgba(255,255,255,.06);border-color:rgba(255,255,255,.4)}
  .btn:disabled{opacity:.5;cursor:not-allowed;transform:none!important}
  .btn-row{display:flex;gap:10px;justify-content:center;flex-wrap:wrap}

  /* INSTAGRAM CONFIRM STATE */
  .ig-confirm{display:none}
  .ig-confirm.show{display:block;animation:fadeUp .4s ease both}
  .check-circle{
    width:64px;height:64px;margin:0 auto 14px;border-radius:50%;
    background:linear-gradient(135deg, #22c55e, #16a34a);
    display:flex;align-items:center;justify-content:center;
    box-shadow:0 10px 30px rgba(34,197,94,.4);
    animation:pop .5s cubic-bezier(.34,1.56,.64,1) both;
  }
  @keyframes pop{0%{transform:scale(0)}100%{transform:scale(1)}}

  /* WHEEL PANEL */
  .wheel-wrap{
    display:grid;
    grid-template-columns: 1fr;
    gap:36px;align-items:center;justify-items:center;
    max-width:560px;margin:0 auto;
  }
  .wheel-shell{
    position:relative;width:min(92vw, 460px);aspect-ratio:1;
    display:flex;align-items:center;justify-content:center;
  }
  .wheel-glow{
    position:absolute;inset:-20px;border-radius:50%;
    background:radial-gradient(circle, rgba(227,6,19,.25), transparent 70%);
    filter:blur(20px);
    animation:pulse 3s ease-in-out infinite;
  }
  @keyframes pulse{
    0%,100%{opacity:.6;transform:scale(1)}
    50%{opacity:1;transform:scale(1.05)}
  }
  .wheel-ring{
    position:absolute;inset:-14px;border-radius:50%;
    background:
      conic-gradient(from 0deg,
        var(--red) 0deg, var(--orange) 90deg,
        var(--red) 180deg, var(--orange) 270deg, var(--red) 360deg);
    padding:6px;
    box-shadow:
      0 0 0 2px rgba(0,0,0,.4),
      0 20px 60px rgba(0,0,0,.5),
      inset 0 0 30px rgba(0,0,0,.3);
  }
  .wheel-ring::before{
    content:"";position:absolute;inset:6px;border-radius:50%;
    background:#0a0d14;
  }
  .wheel-inner{
    position:relative;width:100%;height:100%;border-radius:50%;
    z-index:2;
    transform:rotate(0deg);
    transition:transform 5.5s cubic-bezier(.17,.67,.16,.99);
    box-shadow:inset 0 0 40px rgba(0,0,0,.6);
  }
  .wheel-svg{width:100%;height:100%;display:block;border-radius:50%}
  .wheel-center{
    position:absolute;top:50%;left:50%;transform:translate(-50%,-50%);
    width:80px;height:80px;border-radius:50%;
    background:radial-gradient(circle at 30% 30%, #2a2f3a, #0a0d14);
    display:flex;align-items:center;justify-content:center;
    box-shadow:
      0 8px 24px rgba(0,0,0,.6),
      inset 0 -2px 6px rgba(0,0,0,.5),
      inset 0 2px 4px rgba(255,255,255,.1),
      0 0 0 4px rgba(227,6,19,.3);
    z-index:3;
  }
  .wheel-center img{width:60px;height:auto;filter:drop-shadow(0 2px 4px rgba(0,0,0,.5))}
  .wheel-pointer{
    position:absolute;top:-22px;left:50%;transform:translateX(-50%);
    width:0;height:0;
    border-left:18px solid transparent;
    border-right:18px solid transparent;
    border-top:32px solid var(--bone);
    filter:drop-shadow(0 4px 10px rgba(0,0,0,.5));
    z-index:4;
  }
  .wheel-pointer::after{
    content:"";position:absolute;top:-34px;left:-12px;
    width:24px;height:10px;background:var(--bone);border-radius:4px 4px 0 0;
    box-shadow:0 -2px 8px rgba(0,0,0,.4);
  }

  .wheel-controls{text-align:center;width:100%}
  .wheel-status{
    font-family:'Barlow Condensed', sans-serif;font-weight:600;
    font-size:14px;letter-spacing:.15em;text-transform:uppercase;
    color:rgba(244,241,236,.5);margin-bottom:14px;min-height:18px;
  }
  .spin-btn{
    font-size:18px;padding:18px 40px;
    background:linear-gradient(135deg, var(--orange) 0%, var(--red) 100%);
    box-shadow: 0 12px 36px rgba(242,101,34,.4), inset 0 1px 0 rgba(255,255,255,.25);
  }
  .spin-btn:hover{transform:translateY(-2px);box-shadow:0 16px 44px rgba(242,101,34,.55)}

  /* RESULT REVEAL */
  .reveal{
    display:none;text-align:center;margin-top:24px;
  }
  .reveal.show{display:block;animation:fadeUp .5s ease both}
  .reveal .won-label{
    font-family:'Barlow Condensed', sans-serif;font-weight:700;
    font-size:13px;letter-spacing:.3em;text-transform:uppercase;
    color:var(--orange);margin-bottom:6px;
  }
  .reveal .won-discount{
    font-family:'Russo One', sans-serif;
    font-size:64px;line-height:1;
    background:linear-gradient(135deg, #fff 0%, var(--orange) 50%, var(--red) 100%);
    -webkit-background-clip:text;background-clip:text;color:transparent;
  }

  /* VOUCHER (BONO) PANEL */
  .voucher-panel{padding:0 8px}
  .voucher-intro{text-align:center;margin-bottom:24px}
  .voucher-intro h2{
    font-family:'Russo One', sans-serif;font-size:clamp(24px,4vw,36px);
    text-transform:uppercase;color:#fff;margin-bottom:8px;
  }
  .voucher-intro p{color:rgba(244,241,236,.65);font-size:15px}

  .voucher{
    max-width:680px;margin:0 auto;
    background:
      linear-gradient(135deg, #fff 0%, #f4f1ec 100%);
    color:var(--ink);
    border-radius:20px;
    overflow:hidden;
    position:relative;
    box-shadow:
      0 30px 80px rgba(0,0,0,.5),
      0 0 0 1px rgba(0,0,0,.05);
    transform:perspective(1200px) rotateX(0deg);
  }
  /* Holographic shine */
  .voucher::before{
    content:"";position:absolute;top:0;left:0;right:0;height:6px;
    background:linear-gradient(90deg,
      var(--red) 0%, var(--orange) 25%,
      var(--red) 50%, var(--orange) 75%, var(--red) 100%);
  }
  .voucher::after{
    content:"";position:absolute;top:0;left:-100%;width:50%;height:100%;
    background:linear-gradient(90deg, transparent, rgba(255,255,255,.4), transparent);
    transform:skewX(-20deg);
    animation:shine 6s ease-in-out infinite;
    pointer-events:none;
  }
  @keyframes shine{
    0%, 100%{left:-100%}
    50%{left:200%}
  }

  .voucher-head{
    display:flex;align-items:center;justify-content:space-between;
    padding:22px 28px 16px;border-bottom:1px dashed rgba(0,0,0,.12);
    position:relative;flex-wrap:wrap;gap:14px;
  }
  .voucher-logos{display:flex;align-items:center;gap:16px}
  .voucher-logos img.lf{height:30px;width:auto}
  .voucher-logos img.lr{height:46px;width:auto}
  .voucher-logos .sep{width:1px;height:36px;background:rgba(0,0,0,.15)}
  .voucher-id{
    font-family:'Barlow Condensed', monospace;
    font-size:11px;letter-spacing:.18em;text-transform:uppercase;
    color:rgba(14,14,16,.5);text-align:right;
  }
  .voucher-id strong{display:block;font-size:14px;color:var(--ink);letter-spacing:.12em;margin-top:2px}

  .voucher-body{padding:24px 28px;position:relative}
  .voucher-stamp{
    text-align:center;margin:6px 0 20px;
  }
  .stamp-label{
    font-family:'Barlow Condensed', sans-serif;font-weight:700;
    font-size:11px;letter-spacing:.35em;text-transform:uppercase;
    color:var(--red-dark);
  }
  .stamp-discount{
    font-family:'Russo One', sans-serif;
    font-size:clamp(70px, 16vw, 110px);line-height:.9;
    color:var(--red);
    letter-spacing:-.03em;
    text-shadow: 4px 4px 0 rgba(227,6,19,.15);
    transform:skew(-6deg);display:inline-block;
  }
  .stamp-discount sup{font-size:.5em;vertical-align:top;margin-left:4px}
  .stamp-sub{
    font-family:'Barlow Condensed', sans-serif;font-weight:700;
    font-size:14px;letter-spacing:.25em;text-transform:uppercase;
    color:var(--ink);margin-top:-4px;
  }

  .voucher-info{
    display:grid;grid-template-columns:1fr 1fr;gap:14px;
    padding:16px 0;border-top:1px dashed rgba(0,0,0,.12);
    border-bottom:1px dashed rgba(0,0,0,.12);
  }
  .info-cell .info-label{
    font-family:'Barlow Condensed', sans-serif;font-weight:700;
    font-size:10px;letter-spacing:.25em;text-transform:uppercase;
    color:rgba(14,14,16,.5);margin-bottom:3px;
  }
  .info-cell .info-value{
    font-family:'Barlow Condensed', sans-serif;font-weight:700;
    font-size:18px;color:var(--ink);
  }
  .info-cell.exp .info-value{color:var(--red-dark)}

  .voucher-cta-block{
    text-align:center;padding:18px 0 6px;
  }
  .cta-text{
    font-family:'Russo One', sans-serif;
    font-size:14px;text-transform:uppercase;letter-spacing:.1em;
    color:var(--ink);margin-bottom:12px;
  }
  .cta-text span{color:var(--red)}
  .btn-redeem{
    display:inline-flex;align-items:center;gap:10px;
    font-family:'Russo One', sans-serif;font-size:14px;
    letter-spacing:.1em;text-transform:uppercase;
    color:#fff;text-decoration:none;
    padding:14px 26px;border-radius:10px;
    background:linear-gradient(135deg, var(--red) 0%, var(--red-dark) 100%);
    box-shadow:0 10px 24px rgba(227,6,19,.35);
    transition:all .25s ease;
  }
  .btn-redeem:hover{transform:translateY(-2px);box-shadow:0 14px 30px rgba(227,6,19,.5)}

  .voucher-foot{
    background:var(--ink);color:rgba(244,241,236,.85);
    padding:14px 28px;display:flex;justify-content:space-between;align-items:center;
    flex-wrap:wrap;gap:10px;font-size:12px;
  }
  .voucher-foot .ig{
    font-family:'Barlow Condensed', sans-serif;font-weight:700;
    letter-spacing:.15em;text-transform:uppercase;
    display:flex;align-items:center;gap:8px;
  }
  .voucher-foot .ig svg{width:14px;height:14px}
  .voucher-foot .terms{
    font-size:10px;letter-spacing:.1em;color:rgba(244,241,236,.5);
    text-transform:uppercase;
  }

  /* Decorative side notches */
  .notch{
    position:absolute;width:22px;height:22px;border-radius:50%;
    background:#0a0d14;
  }
  .notch.left{left:-11px;top:50%;transform:translateY(-50%)}
  .notch.right{right:-11px;top:50%;transform:translateY(-50%)}

  /* Voucher actions below */
  .voucher-actions{
    display:flex;gap:10px;justify-content:center;margin-top:24px;flex-wrap:wrap;
  }

  /* Confetti */
  .confetti{
    position:fixed;top:-20px;width:10px;height:14px;
    pointer-events:none;z-index:50;
    animation:fall linear forwards;
  }
  @keyframes fall{
    to{transform:translateY(110vh) rotate(720deg);opacity:0}
  }

  /* MOBILE */
  @media (max-width:600px){
    header.top{flex-direction:column;text-align:center;gap:12px}
    .ig-card{padding:28px 20px}
    .voucher-head{flex-direction:column;text-align:center}
    .voucher-id{text-align:center}
    .voucher-info{grid-template-columns:1fr}
    .voucher-foot{flex-direction:column;text-align:center}
    .stamp-discount{font-size:78px}
  }
</style>
</head>
<body>
<div class="speedlines"></div>

<div class="app">

  <header class="top">
    <div class="brand-mark">
      <img src="data:image/png;base64,
